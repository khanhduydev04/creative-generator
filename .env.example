# ─── Supabase (REQUIRED) ─────────────────────────────────────────────────────
# Supabase project URL and anon key — used for DB, Storage, and Auth
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ─── Google AI Studio (REQUIRED) ─────────────────────────────────────────────
# Gemini 2.5 Flash — used for product page reading, concept skill generation,
# competitor analysis, and brand intelligence
GOOGLE_API_KEY=your-google-ai-studio-api-key-here

# ─── Google Cloud Console (OPTIONAL) ─────────────────────────────────────────
# Google Sheets API v4 — used for competitor data with hyperlink extraction
# Also used for Google Fonts API proxy (font picker in brand setup)
# If not set, competitor data falls back to CSV export or cached data
GOOGLE_CONSOLE_API_KEY=your-google-console-api-key-here

# Legacy spreadsheet ID — only needed for hardcoded market GID map (US market)
# New per-product market system stores spreadsheet IDs in the database
SPREADSHEET_ID=your-spreadsheet-id-here

# ─── KIE AI (REQUIRED) ──────────────────────────────────────────────────────
# KIE AI image generation API — nano-banana-2 model
# Used for generating static ad images from assembled prompts
KIE_API_KEY=your-kie-api-key-here
