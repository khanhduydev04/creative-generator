# ═══════════════════════════════════════════════════════════════════════════════
# Static Ads Generator — Environment Variables (example)
# Copy to .env.local and fill in real values. See .env.local.template for full notes.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── 1. Supabase (REQUIRED) ──────────────────────────────────────────────────
# DB, Storage, Auth — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
# service_role secret — REQUIRED for cron + admin (bypasses RLS). Server-side only.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ─── 2. AI / LLM (REQUIRED) ──────────────────────────────────────────────────
# Gemini 2.5 Flash — product reading, concepts, competitor analysis
GOOGLE_API_KEY=your-google-ai-studio-api-key-here
# Claude — content adapt, brand intelligence
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# KIE AI — image generation (nano-banana-2)
KIE_API_KEY=your-kie-api-key-here
# Encryption master key for user_api_keys — 64-char hex (32 bytes)
ADLANCE_ENCRYPTION_KEY=your-32-byte-hex-key-here

# ─── 3. TTS / Voice (OPTIONAL) ───────────────────────────────────────────────
# Vbee TTS — provider = vbee
VBEE_API_KEY=your-vbee-api-key-here
# ElevenLabs TTS — provider = elevenlabs (v3 / flash v2.5)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# ─── 4. Apify sync + Cron (OPTIONAL) ─────────────────────────────────────────
# Apify token — console.apify.com → Integrations
APIFY_TOKEN=your-apify-token-here
# Cron auth secret — Vercel auto-sends as Authorization: Bearer <CRON_SECRET>
CRON_SECRET=your-cron-secret-here

# ─── 5. Google Sheets / Fonts (OPTIONAL) ─────────────────────────────────────
# Sheets API v4 + Fonts API — falls back to CSV if unset
GOOGLE_CONSOLE_API_KEY=your-google-console-api-key-here
# Legacy US-market spreadsheet ID (new markets stored in DB)
SPREADSHEET_ID=your-spreadsheet-id-here

# ─── 6. Email / Brevo (OPTIONAL) ─────────────────────────────────────────────
# Brevo transactional email — skip if email features unused
BREVO_API_KEY=your-brevo-api-key-here
EMAIL_SENDER_NAME=Ladospice
EMAIL_SENDER_ADDRESS=no-reply@your-domain.com

# ─── 7. App / misc (OPTIONAL) ────────────────────────────────────────────────
# Public base URL — used by sitemap.ts, robots.ts
NEXT_PUBLIC_APP_URL=https://your-app-domain.com
