# ═══════════════════════════════════════════════════════════════════════════════
# Static Ads Generator — Environment Variables
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git
#
# Groups:
#   1. Supabase            (REQUIRED)
#   2. AI / LLM            (REQUIRED)
#   3. TTS / Voice         (OPTIONAL — per provider)
#   4. Apify sync + Cron   (OPTIONAL — competitor video pull)
#   5. Google Sheets/Fonts (OPTIONAL)
#   6. Email / Brevo       (OPTIONAL)
#   7. App / misc          (OPTIONAL)
# ═══════════════════════════════════════════════════════════════════════════════

# ─── 1. Supabase (REQUIRED) ──────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project Settings → API
# Used by: DB queries, Storage uploads, Auth
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# Service-role key — REQUIRED for cron + admin operations
# Get from: Project Settings → API → service_role secret
# Used by: createAdminClient() — bypasses RLS in /api/cron/sync-apify and admin routes
# NEVER expose to the browser. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here

# ─── 2. AI / LLM (REQUIRED) ──────────────────────────────────────────────────
# Google AI Studio — Gemini 2.5 Flash
# Get from: https://aistudio.google.com/apikey
# Used by: product page reading, concept skills, competitor analysis
GOOGLE_API_KEY=AIza...your-key-here

# Anthropic Claude — Claude Haiku 4.5 / Sonnet
# Get from: https://console.anthropic.com/settings/keys
# Used by: content adapt, brand intelligence, competitor analysis
ANTHROPIC_API_KEY=sk-ant-...your-key-here

# KIE AI — image generation (nano-banana-2 model)
# Get from: KIE AI dashboard
# Used by: static ad image generation
KIE_API_KEY=your-kie-api-key-here

# Encryption master key for stored credentials (user_api_keys table)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 64-char hex (32 bytes). DO NOT change in production without re-encrypting all rows.
ADLANCE_ENCRYPTION_KEY=

# ─── 3. TTS / Voice (OPTIONAL) ───────────────────────────────────────────────
# Vbee TTS — Vietnamese voice provider
# Get from: Vbee dashboard
# Used by: audio generation (provider = vbee)
VBEE_API_KEY=

# ElevenLabs TTS — second voice provider (v3 / flash v2.5 models)
# Get from: https://elevenlabs.io → Profile → API Keys
# Used by: /api/video/elevenlabs/voices and audio generation (provider = elevenlabs)
ELEVENLABS_API_KEY=

# MiniMax Audio TTS — third voice provider (needs BOTH key and group id)
# Get from: MiniMax platform dashboard
# Used by: audio generation (provider = minimax)
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# ─── 4. Apify sync + Cron (OPTIONAL) ─────────────────────────────────────────
# Apify token — pull last succeeded run for each brand's actor-task
# Get from: https://console.apify.com/account/integrations
# Used by: /api/cron/sync-apify and the manual "Sync ngay" button
APIFY_TOKEN=apify_api_...your-token-here

# Shared secret Vercel Cron sends via: Authorization: Bearer <CRON_SECRET>
# Protects /api/cron/* from unauthorized calls. Vercel auto-attaches this header
# when the env var is set — no manual config needed.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ─── 5. Google Sheets / Fonts (OPTIONAL) ─────────────────────────────────────
# Google Cloud Console key — Sheets API v4 + Fonts API
# Get from: https://console.cloud.google.com/apis/credentials
# Enable: Google Sheets API v4, Google Fonts API
# Used by: competitor data hyperlink extraction, font picker. Falls back to CSV.
GOOGLE_CONSOLE_API_KEY=AIza...your-key-here

# Legacy spreadsheet ID — only for hardcoded US-market competitor data (legacy path)
# New per-product market system stores spreadsheet IDs in the database
SPREADSHEET_ID=your-spreadsheet-id-here

# ─── 6. Email / Brevo (OPTIONAL) ─────────────────────────────────────────────
# Brevo (Sendinblue) transactional email
# Get from: https://app.brevo.com → SMTP & API → API Keys
# Used by: src/lib/email.ts (notifications). Skip if email features unused.
BREVO_API_KEY=
EMAIL_SENDER_NAME=Ladospice
EMAIL_SENDER_ADDRESS=no-reply@your-domain.com

# ─── 7. App / misc (OPTIONAL) ────────────────────────────────────────────────
# Public base URL of the deployed app
# Used by: sitemap.ts, robots.ts. Defaults to localhost in dev.
NEXT_PUBLIC_APP_URL=https://your-app-domain.com
