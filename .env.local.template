# ═══════════════════════════════════════════════════════════════════════════════
# Static Ads Generator — Environment Variables
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Supabase (REQUIRED) ─────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project Settings → API
# Used by: DB queries, Storage uploads, Auth, Edge Functions
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# ─── Google AI Studio (REQUIRED) ─────────────────────────────────────────────
# Get from: https://aistudio.google.com/apikey
# Used by: Gemini 2.5 Flash — product page reading, concept skills, competitor analysis
GOOGLE_API_KEY=AIza...your-key-here

# ─── Google Cloud Console (OPTIONAL) ─────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Enable: Google Sheets API v4, Google Fonts API
# Used by: Competitor data with hyperlink extraction, Google Fonts picker
# Falls back to CSV export if not set
GOOGLE_CONSOLE_API_KEY=AIza...your-key-here

# ─── Legacy Spreadsheet ID (OPTIONAL) ────────────────────────────────────────
# Only needed for hardcoded US market competitor data (legacy path)
# New per-product market system stores spreadsheet IDs in database
SPREADSHEET_ID=your-spreadsheet-id-here

# ─── KIE AI (REQUIRED) ──────────────────────────────────────────────────────
# Get from: KIE AI dashboard
# Used by: Image generation (nano-banana-2 model)
KIE_API_KEY=your-kie-api-key-here

# ─── Adlance encryption master key (REQUIRED) ───────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 64-character hex (32 bytes). DO NOT commit the actual value.
# DO NOT change in production without re-encrypting all rows in user_api_keys.
ADLANCE_ENCRYPTION_KEY=

# ─── Anthropic Claude (TRANSITIONAL — removed once BYOK ships) ──────────────
# Get from: https://console.anthropic.com/settings/keys
# Used by: Claude Haiku 4.5 — content adapt, brand intelligence, competitor analysis
# Phase 3 of BYOK pivot moves this to per-user storage; this server-side fallback
# stays around only until that refactor lands.
ANTHROPIC_API_KEY=sk-ant-...your-key-here

# ─── Vbee TTS (OPTIONAL) ─────────────────────────────────────────────────────
# Get from: Vbee dashboard
# Used by: Stage 5 voice generation
VBEE_API_KEY=

# ─── Apify pull-sync (OPTIONAL) ──────────────────────────────────────────────
# Token: https://console.apify.com/account/integrations
# Used by: /api/cron/sync-apify — pull last succeeded run for each brand's actor-task
APIFY_TOKEN=apify_api_...your-token-here

# Shared secret Vercel Cron sends via: Authorization: Bearer <CRON_SECRET>
# Protects /api/cron/* from unauthorized calls
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
